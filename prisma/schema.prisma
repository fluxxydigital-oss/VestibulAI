generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(uuid())
  name            String?
  email           String         @unique
  passwordHash    String
  targetCourse    String?        // ex: "Medicina", "Engenharia"
  dailyStudyHours Float?         // ex: 4.5
  plan            String         @default("FREE") // FREE, PRO, PREMIUM
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  progress        UserProgress[]
  studyPlans      StudyPlan[]
  essays          Essay[]
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique // ex: "Matemática", "Português", "Biologia"
  description String?
  weight      Float    @default(1.0) // Peso para o curso desejado

  questions   Question[]
  progress    UserProgress[]
  studyPlans  StudyPlan[]
}

model Question {
  id            String   @id @default(uuid())
  subjectId     String
  statement     String   @db.Text
  options       Json     // Array of { id, text }
  correctOption String   // id of the correct option
  difficulty    Int      // 1-5
  source        String?  // ex: "ENEM 2023", "UERJ 2024", "AI Generated"
  createdAt     DateTime @default(now())

  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id               String   @id @default(uuid())
  userId           String
  subjectId        String
  questionsAnswered Int      @default(0)
  correctAnswers   Int      @default(0)
  estimatedLevel   Float    @default(1.0) // 1.0 to 5.0
  lastActivityAt   DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject          Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model StudyPlan {
  id          String   @id @default(uuid())
  userId      String
  subjectId   String
  date        DateTime @db.Date // Data prevista de estudo
  durationMin Int      // Duração em minutos
  status      String   @default("PENDING") // PENDING, COMPLETED, MISSED

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Essay {
  id          String   @id @default(uuid())
  userId      String
  theme       String
  content     String   @db.Text
  score       Json?    // Detalhamento de notas por competência
  feedback    String?  @db.Text
  status      String   @default("DRAFT") // DRAFT, SUBMITTED, GRADED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
